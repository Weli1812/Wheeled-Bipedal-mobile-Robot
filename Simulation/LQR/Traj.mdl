      <P Name="subviewer">30</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [xd, yd, thetad, vd, wd] = referenceGenerator(t, P, theta_ref, vd_ref, wd_ref, Ts_ref)

idx = round(t / Ts_ref) + 1;

if idx &lt; 1
    idx = 1;
elseif idx &gt; size(P,1)
    idx = size(P,1);
end

xd     = P(idx,1);
yd     = P(idx,2);
thetad = theta_ref(idx,1);
vd     = vd_ref(idx,1);
wd     = wd_ref(idx,1);</P>
      </eml>
    </state>
